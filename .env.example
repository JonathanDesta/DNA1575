# ====== Stripe ======
# Test mode keys start with sk_test_ / pk_test_
# Live mode keys start with sk_live_ / pk_live_
# Get them at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# Webhook signing secret. Created when you add the webhook endpoint in Stripe.
# https://dashboard.stripe.com/webhooks → Add endpoint → copy "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SIGNING_SECRET

# ====== Resend (branded confirmation email) ======
# Sign up at https://resend.com — free tier covers 3,000 emails/month.
# After signup: Domains → Add Domain → verify DNS records → API Keys → Create.
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY

# Address the confirmation email is sent FROM.
# Must be a verified address on a domain you've verified in Resend.
# Format: "Display Name <address@yourdomain.com>"
MAIL_FROM=DNA1575 <hello@dna1575.com>

# Where customer replies go. Use whatever inbox you actually check.
MAIL_REPLY_TO=dna1575prep@gmail.com

# Comma-separated emails to BCC on every booking confirmation so you and Alex
# both see who booked. Optional — leave blank to skip.
MAIL_CC_INTERNAL=jdjonathandesta@gmail.com,alex.alexandrov734@gmail.com

# ====== Upstash Redis (capacity tracking + waitlist storage) ======
# Set automatically when you install the Upstash Redis integration from the
# Vercel Marketplace and connect it to this project. Do NOT set these manually.
# Vercel dashboard → Integrations → Browse Marketplace → Upstash Redis → Add
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ====== Vercel Cron ======
# Set this to any long random string. Vercel sends it as a Bearer token on every
# scheduled cron invocation so the /api/cron-cancel endpoint can verify the request.
# Generate one with: openssl rand -hex 32
CRON_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING

# ====== Site URL (optional) ======
# Public origin of the site (used in confirmation/magic-link emails).
# If unset, the server falls back to the request's x-forwarded-host, and finally
# to the hardcoded deployment URL. Set this once you add a custom domain.
SITE_URL=https://dna1575-deploy.vercel.app

# ====== Frontend ======
# After everything is set up, also paste your PUBLISHABLE key (pk_live_... or pk_test_...)
# into public/index.html where it says STRIPE_PUBLISHABLE_KEY = '...'
# (The publishable key is safe to expose in browser code — only the secret key must stay server-side.)
